---
import Layout from '../../layouts/Layout.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import { useTranslations } from '../../i18n/index';

export function getStaticPaths() {
  return [
    { params: { lang: 'en' } },
    { params: { lang: 'de' } },
  ];
}

const { lang } = Astro.params;
const t = useTranslations(lang);
const otherLang = lang === 'en' ? 'de' : 'en';

const projects = [
  {
    name: "flag-quiz",
    description: t('flagQuizDescription'),
    tech: ["Angular", "TypeScript", "Go", "SQLite", "Docker", "Nginx"],
    github: "https://github.com/DukeXCode/flag-quiz-frontend",
    demo: ""
  },
  {
    name: "e-id-demo",
    description: t('eIdDescription'),
    tech: ["React Native", "TypeScript", "Python"],
    github: "https://github.com/DukeXCode/e-id-demo",
    demo: ""
  },
  {
    name: "cloud-condense",
    description: t('cloudCondenseDescription'),
    tech: ["Vue", "TypeScript", "Java", "Spring Boot", "Microsoft SQL", "Docker"],
    github: "https://github.com/jzelAdmin2006/Hackathon2023-CloudCondense",
    demo: ""
  },
  {
    name: "portfolio",
    description: t('portfolioDescription'),
    tech: ["Astro", "TypeScript", "Tailwind CSS"],
    github: "https://github.com/DukeXCode/portfolio",
    demo: ""
  }
];

const skills = [
  {
    name: "FRONTEND",
    items: ["Angular", "React", "TypeScript", "Node.js", "Tailwind CSS"]
  },
  {
    name: "BACKEND",
    items: ["Java", "Kotlin", "Python", "Spring Boot", "PostgreSQL", "SQLite", "Gradle"]
  },
  {
    name: "DEVOPS",
    items: ["Docker", "Kubernetes", "Jenkins", "Linux"]
  },
  {
    name: "BI",
    items: ["Qlik Sense", "Microsoft SQL"]
  },
  {
    name: "MOBILE",
    items: ["Ionic", "Capacitor", "React Native"]
  },
];

let pid = 100;
const skillsPids = {};
for (const category of skills) {
  for (const item of category.items) {
    skillsPids[item] = pid++;
  }
}

const buildDate = new Date().toISOString().split('T')[0];
---

<Layout title="Naïm Giger — Portfolio">
  <!-- Main Content -->
  <div class="relative grid-bg min-h-screen">
    <!-- Background Particles -->
    <div class="fixed inset-0 pointer-events-none overflow-hidden">
      <div class="data-particle" style="top:15%;left:10%;animation:particle 5s ease-in-out infinite;animation-delay:0s"></div>
      <div class="data-particle" style="top:45%;left:85%;animation:particle 7s ease-in-out infinite;animation-delay:1s"></div>
      <div class="data-particle" style="top:75%;left:20%;animation:particle 6s ease-in-out infinite;animation-delay:2s"></div>
      <div class="data-particle" style="top:25%;left:75%;animation:particle 8s ease-in-out infinite;animation-delay:0.5s"></div>
      <div class="data-particle" style="top:60%;left:50%;animation:particle 5.5s ease-in-out infinite;animation-delay:1.5s"></div>
      <div class="data-particle" style="top:85%;left:70%;animation:particle 6.5s ease-in-out infinite;animation-delay:2.5s"></div>
    </div>

    <!-- Navigation / Status Bar -->
    <nav class="relative z-10 flex items-center justify-between px-6 py-3 border-b border-neon-border/50">
      <div class="flex items-center gap-4">
        <div class="flex items-center gap-2">
          <span class="w-2 h-2 rounded-full bg-neon-green animate-glow-pulse-fast"></span>
          <span class="font-mono text-xs sm:text-sm text-neon-green/70">ONLINE</span>
        </div>
          <span class="font-mono text-xs sm:text-sm text-neon-dim hidden sm:inline">
            <span class="text-neon-cyan">admin</span>@<span class="text-neon-purple">dukex.dev</span>:<span class="text-neon-amber">~</span>
          </span>
      </div>
      <div class="flex items-center gap-4">
        <span class="font-mono text-xs sm:text-sm text-neon-dim/50 hidden sm:inline" id="clock">SYS: 00:00:00</span>
        <a href={`/${otherLang}/`} class="px-2 py-1 font-mono text-xs sm:text-sm text-neon-dim border border-neon-border transition-all duration-300 hover:text-neon-cyan hover:border-neon-cyan/30 hover:glow-box-cyan" title="Switch language">
          <span class="text-neon-cyan">&gt;</span> {otherLang}
        </a>
        <a href="https://github.com/DukeXCode" class="p-1.5 text-neon-dim transition-colors duration-300 hover:text-neon-purple">
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" aria-label="GitHub">
            <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/>
          </svg>
        </a>
      </div>
    </nav>

    <!-- Hero Section -->
    <section class="relative z-10 px-6 pt-16 pb-12">
      <div class="mx-auto max-w-5xl">
        <div class="grid grid-cols-1 lg:grid-cols-5 gap-8 items-start">
          <div class="lg:col-span-3 space-y-6">
            <div class="font-mono text-sm text-neon-cyan/60 animate-fade-in" style="animation-delay: 0.2s">
              <span class="text-neon-purple">~/</span> $ <span class="text-neon-dim">cat welcome.txt</span>
            </div>
            <h1 class="font-display text-5xl sm:text-6xl lg:text-7xl font-black text-neon-text leading-none tracking-wide animate-fade-in" style="animation-delay: 0.4s">
              <span class="glow-purple block">NAÏM</span>
              <span class="block text-neon-text/90">GIGER</span>
            </h1>
            <div class="font-mono text-sm sm:text-base text-neon-dim/90 leading-relaxed animate-fade-in" style="animation-delay: 0.6s">
              <span class="text-neon-purple">></span> {t('slogan')}
            </div>
            <div class="font-mono text-sm text-neon-dim/60 animate-fade-in" style="animation-delay: 0.8s">
              <span class="text-neon-purple">></span> {t('currently')}
            </div>
          </div>

          <!-- System Info Panel -->
          <div class="lg:col-span-2 animate-slide-up opacity-0" style="animation-delay: 1s">
            <div class="border border-neon-border/50 bg-neon-surface/40 p-4 glow-box-purple">
              <div class="flex items-center gap-2 mb-4 pb-3 border-b border-neon-border/30">
                <div class="flex gap-1.5">
                  <span class="w-2 h-2 rounded-full bg-neon-red"></span>
                  <span class="w-2 h-2 rounded-full bg-neon-amber"></span>
                  <span class="w-2 h-2 rounded-full bg-neon-green"></span>
                </div>
                <span class="font-mono text-xs sm:text-sm text-neon-dim/60 uppercase tracking-widest">system info</span>
              </div>
              <div class="space-y-2 font-mono text-xs sm:text-sm">
                <div class="flex justify-between">
                  <span class="text-neon-dim">USER</span>
                  <span class="text-neon-text">admin</span>
                </div>
                <div class="flex justify-between">
                  <span class="text-neon-dim">HOST</span>
                  <span class="text-neon-cyan">dukex.dev</span>
                </div>
                <div class="flex justify-between">
                  <span class="text-neon-dim">OS</span>
                  <span class="text-neon-text">DukexOS / v2.0</span>
                </div>
                <div class="flex justify-between">
                  <span class="text-neon-dim">SHELL</span>
                  <span class="text-neon-text">/bin/dxsh</span>
                </div>
                <div class="flex justify-between">
                  <span class="text-neon-dim">UPTIME</span>
                  <span class="text-neon-green">∞</span>
                </div>
                <div class="flex justify-between">
                  <span class="text-neon-dim">LOCALE</span>
                  <span class="text-neon-text">{lang === 'en' ? 'en_US.UTF-8' : 'de_CH.UTF-8'}</span>
                </div>
                <div class="flex justify-between">
                  <span class="text-neon-dim">NET</span>
                  <span class="text-neon-green">● connected</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Sections Separator -->
    <div class="relative z-10 mx-auto max-w-5xl px-6">
      <div class="border-t border-neon-border/30"></div>
    </div>

    <!-- Projects Section -->
    <section class="relative z-10 px-6 py-12">
      <div class="mx-auto max-w-5xl">
        <div class="flex items-center gap-3 mb-8">
          <span class="font-mono text-sm text-neon-cyan/60">~/projects</span>
          <span class="font-mono text-sm text-neon-purple">$</span>
          <span class="font-mono text-sm text-neon-dim">ls -la</span>
        </div>
        <div class="grid gap-4">
          {projects.map((project, i) => (
            <div class="opacity-0 animate-slide-up" style={`animation-delay: ${0.1 * i}s`}>
              <ProjectCard project={project} />
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Sections Separator -->
    <div class="relative z-10 mx-auto max-w-5xl px-6">
      <div class="border-t border-neon-border/30"></div>
    </div>

    <!-- Skills Section -->
    <section class="relative z-10 px-6 py-12">
      <div class="mx-auto max-w-5xl">
        <div class="flex items-center gap-3 mb-8">
          <span class="font-mono text-sm text-neon-cyan/60">~/skills</span>
          <span class="font-mono text-sm text-neon-purple">$</span>
          <span class="font-mono text-sm text-neon-dim">ps aux | grep runtime</span>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {skills.map((category, i) => (
            <div class="opacity-0 animate-slide-up border border-neon-border/40 bg-neon-surface/30 p-4 transition-all duration-500 hover:border-neon-purple/30 hover:glow-box-purple" style={`animation-delay: ${0.15 * i}s`}>
              <div class="flex items-center justify-between mb-3 pb-2 border-b border-neon-border/20">
                <h3 class="font-mono text-xs sm:text-sm tracking-widest text-neon-purple/80">{category.name}</h3>
                <span class="flex items-center gap-1.5">
                  <span class="w-1.5 h-1.5 rounded-full bg-neon-green animate-glow-pulse-fast"></span>
                  <span class="font-mono text-[10px] sm:text-xs text-neon-green/60">RUNNING</span>
                </span>
              </div>
              <ul class="space-y-1.5">
                {category.items.map(item => (
                  <li class="flex items-center gap-2">
                    <span class="font-mono text-xs sm:text-sm text-neon-dim/40">PID.{skillsPids[item].toString().padStart(3, '0')}</span>
                    <span class="font-mono text-sm text-neon-text/80">{item}</span>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Footer -->
    <footer class="relative z-10 px-6 py-8">
      <div class="mx-auto max-w-5xl">
        <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 pt-6 border-t border-neon-border/30">
          <div class="flex items-center gap-2">
          <span class="font-mono text-xs sm:text-sm text-neon-cyan">~/</span>
          <span class="font-mono text-xs sm:text-sm text-neon-purple">$</span>
          <span class="animate-blink text-neon-cyan text-xs sm:text-sm">_</span>
          </div>
          <div class="flex items-center gap-4 font-mono text-xs sm:text-sm text-neon-dim/50">
            <span>BUILD: {buildDate}</span>
            <span>STACK: ASTRO + TAILWIND</span>
          </div>
        </div>
      </div>
    </footer>
  </div>

  <script>
    const clock = document.getElementById('clock');
    if (clock) {
      function updateClock() {
        const now = new Date();
        const h = String(now.getHours()).padStart(2, '0');
        const m = String(now.getMinutes()).padStart(2, '0');
        const s = String(now.getSeconds()).padStart(2, '0');
        clock.textContent = `SYS: ${h}:${m}:${s}`;
      }
      updateClock();
      setInterval(updateClock, 1000);
    }
  </script>
</Layout>
