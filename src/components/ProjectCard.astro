---
interface Props {
  project: {
    name: string;
    description: string;
    github: string;
    demo: string;
    tech: string[];
  };
}

const { project } = Astro.props;

---

<div class="group relative">
  <div class="relative p-5 bg-neon-surface/80 border border-neon-border rounded-sm transition-all duration-500 hover:border-neon-purple/40 hover:glow-box-purple hover:-translate-y-0.5">
    <div class="flex items-start justify-between">
      <div class="flex items-start gap-3 min-w-0">
        <span class="text-neon-purple/60 font-mono text-xs sm:text-sm shrink-0 leading-5 sm:leading-6 mt-0.5">drwxr-xr-x</span>
        <div class="min-w-0 space-y-2">
          <div class="flex items-center justify-between gap-2">
            <h3 class="font-mono text-sm text-neon-text truncate">{project.name}</h3>
            {project.github && (
              <a href={project.github} class="p-1.5 text-neon-dim shrink-0 transition-colors duration-300 hover:text-neon-purple">
                <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="currentColor" aria-label="GitHub">
                  <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/>
                </svg>
              </a>
            )}
          </div>
          <p class="text-xs sm:text-sm text-neon-dim/80 leading-relaxed">{project.description}</p>
          <div class="flex flex-wrap gap-1.5">
            {project.tech.map(tech => (
              <span class="px-2 py-0.5 text-xs sm:text-sm font-mono text-neon-purple/70 bg-neon-purple/5 border border-neon-purple/10 transition-all duration-300 group-hover:bg-neon-purple/10 group-hover:border-neon-purple/20">
                {tech}
              </span>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
